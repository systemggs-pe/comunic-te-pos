rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedUser() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          'brand050103@gmail.com',
          'lauryruyz50@gmail.com'
        ];
    }

    function isSharedApp(appId, scope) {
      return appId == 'comunicate-pos' && scope == 'shared';
    }

    function canUseSharedData(appId, scope) {
      return isAllowedUser() && isSharedApp(appId, scope);
    }

    function hasOnly(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function optionalString(field, maxSize) {
      return !(field in request.resource.data)
        || (request.resource.data[field] is string
          && request.resource.data[field].size() <= maxSize);
    }

    function optionalBool(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] is bool;
    }

    function optionalList(field, maxSize) {
      return !(field in request.resource.data)
        || (request.resource.data[field] is list
          && request.resource.data[field].size() <= maxSize);
    }

    function validDocumento(value) {
      return value is string && value.matches('^[A-Z0-9-]{6,15}$');
    }

    function validTipoDocumento(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] in ['DNI', 'CE', 'PASAPORTE', 'RUC'];
    }

    function validMedioPago(field) {
      return !(field in request.resource.data)
        || request.resource.data[field] in ['EFECTIVO', 'TRANSFERENCIA', 'TARJETA'];
    }

    function validImei(value) {
      return value is string && value.matches('^\\d{15}$');
    }

    function validOptionalImei(field) {
      return !(field in request.resource.data)
        || (request.resource.data[field] is string
          && (request.resource.data[field] == ''
            || request.resource.data[field].matches('^\\d{15}$')));
    }

    function validPhone(field) {
      return !(field in request.resource.data)
        || (request.resource.data[field] is string
          && request.resource.data[field].matches('^\\d{0,9}$'));
    }

    function validMoney(field) {
      return request.resource.data[field] is string
        && request.resource.data[field].matches('^\\d+(\\.\\d{1,2})?$')
        && request.resource.data[field].size() <= 20;
    }

    function validIsoDate(field) {
      return request.resource.data[field] is string
        && request.resource.data[field].size() <= 40;
    }

    function validCliente(clienteId) {
      return hasOnly(['tipoDocumento', 'dni', 'nombre', 'celular', 'celularRef', 'correo', 'direccion', 'celulares', 'correos'])
        && request.resource.data.dni == clienteId
        && validDocumento(request.resource.data.dni)
        && validTipoDocumento('tipoDocumento')
        && optionalString('nombre', 160)
        && validPhone('celular')
        && validPhone('celularRef')
        && optionalString('correo', 180)
        && optionalString('direccion', 300);
    }

    function validEquipo(equipoId) {
      return hasOnly([
          'idEquipo', 'idDuenio', 'imei2', 'sn', 'marca', 'modelo',
          'nombreComercial', 'isRegistrado', 'imei1Registrado',
          'imei2Registrado', 'isVendido', 'ram', 'memoria', 'color'
        ])
        && request.resource.data.idEquipo == equipoId
        && validImei(request.resource.data.idEquipo)
        && validDocumento(request.resource.data.idDuenio)
        && validOptionalImei('imei2')
        && optionalString('sn', 80)
        && optionalString('marca', 80)
        && optionalString('modelo', 100)
        && optionalString('nombreComercial', 140)
        && optionalString('ram', 12)
        && optionalString('memoria', 12)
        && optionalString('color', 80)
        && optionalBool('isRegistrado')
        && optionalBool('imei1Registrado')
        && optionalBool('imei2Registrado')
        && optionalBool('isVendido');
    }

    function validRegistro() {
      return hasOnly([
          'tipoDocumentoCliente', 'dniCliente', 'celularCliente', 'celularRef', 'imeiEquipo',
          'imeiRegistrado', 'imei2Equipo', 'modeloEquipo', 'marcaEquipo',
          'nombreComercialEquipo', 'estado', 'operador', 'tipo', 'precio',
          'fecha', 'nRegistro', 'pdfDniUrl', 'pdfCajaUrl', 'pdfReciboUrl'
        ])
        && validDocumento(request.resource.data.dniCliente)
        && validTipoDocumento('tipoDocumentoCliente')
        && validImei(request.resource.data.imeiEquipo)
        && validImei(request.resource.data.imeiRegistrado)
        && validOptionalImei('imei2Equipo')
        && validPhone('celularCliente')
        && validPhone('celularRef')
        && request.resource.data.estado in ['NO BLOQUEADO', 'BLOQUEADO']
        && request.resource.data.operador in ['CLARO', 'MOVISTAR', 'ENTEL', 'BITEL']
        && request.resource.data.tipo in ['TIENDA', 'EXTERNO', 'PASE']
        && validMoney('precio')
        && validIsoDate('fecha')
        && optionalString('modeloEquipo', 100)
        && optionalString('marcaEquipo', 80)
        && optionalString('nombreComercialEquipo', 140)
        && optionalString('nRegistro', 30)
        && optionalString('pdfDniUrl', 1200)
        && optionalString('pdfCajaUrl', 1200)
        && optionalString('pdfReciboUrl', 1200);
    }

    function validVenta() {
      return hasOnly([
          'tipoDocumentoCliente', 'dniCliente', 'imeiEquipo', 'imei2Equipo', 'sn', 'modeloEquipo',
          'marcaEquipo', 'nombreComercial', 'ram', 'memoria', 'color',
          'precio', 'medioPago', 'fecha', 'nVenta'
        ])
        && validDocumento(request.resource.data.dniCliente)
        && validTipoDocumento('tipoDocumentoCliente')
        && validMedioPago('medioPago')
        && validImei(request.resource.data.imeiEquipo)
        && validOptionalImei('imei2Equipo')
        && validMoney('precio')
        && validIsoDate('fecha')
        && optionalString('sn', 80)
        && optionalString('modeloEquipo', 100)
        && optionalString('marcaEquipo', 80)
        && optionalString('nombreComercial', 140)
        && optionalString('ram', 12)
        && optionalString('memoria', 12)
        && optionalString('color', 80)
        && optionalString('nVenta', 30);
    }

    function validLogo() {
      return hasOnly(['dataUrl'])
        && request.resource.data.dataUrl is string
        && request.resource.data.dataUrl.matches('^data:image/(png|jpeg|jpg|webp);base64,.*')
        && request.resource.data.dataUrl.size() <= 900000;
    }

    function validBoletaEmisor(emisor) {
      return emisor is map
        && emisor.keys().hasOnly(['nombre', 'rut', 'direccion'])
        && emisor.nombre is string
        && emisor.nombre.size() <= 220
        && emisor.rut is string
        && emisor.rut.size() <= 40
        && emisor.direccion is string
        && emisor.direccion.size() <= 300;
    }

    function validBoletaExtranjeraEmisores() {
      return hasOnly(['formato1', 'formato2', 'formato3'])
        && validBoletaEmisor(request.resource.data.formato1)
        && validBoletaEmisor(request.resource.data.formato2)
        && validBoletaEmisor(request.resource.data.formato3);
    }

    function validProblemaApp() {
      return request.resource.data.keys().hasAll([
          'titulo', 'descripcion', 'severidad', 'solucion', 'resuelto',
          'createdAt', 'updatedAt', 'resolvedAt', 'resolvedBy'
        ])
        && hasOnly([
          'titulo', 'descripcion', 'archivos', 'severidad', 'solucion', 'resuelto',
          'createdAt', 'updatedAt', 'resolvedAt', 'resolvedBy'
        ])
        && request.resource.data.titulo is string
        && request.resource.data.titulo.size() > 0
        && request.resource.data.titulo.size() <= 220
        && request.resource.data.descripcion is string
        && request.resource.data.descripcion.size() <= 1000
        && optionalList('archivos', 20)
        && request.resource.data.severidad in ['critico', 'alto', 'medio', 'bajo']
        && request.resource.data.solucion is string
        && request.resource.data.solucion.size() <= 2000
        && request.resource.data.resuelto is bool
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (request.resource.data.resolvedAt == null || request.resource.data.resolvedAt is timestamp)
        && request.resource.data.resolvedBy is string
        && request.resource.data.resolvedBy.size() <= 180;
    }

    function validChangelogProblema() {
      return request.resource.data.keys().hasAll([
          'problemaId', 'titulo', 'severidad', 'solucion', 'resumen',
          'createdAt', 'createdBy'
        ])
        && hasOnly([
          'problemaId', 'titulo', 'archivos', 'severidad', 'solucion', 'resumen',
          'createdAt', 'createdBy'
        ])
        && request.resource.data.problemaId is string
        && request.resource.data.problemaId.size() <= 120
        && request.resource.data.titulo is string
        && request.resource.data.titulo.size() > 0
        && request.resource.data.titulo.size() <= 220
        && optionalList('archivos', 20)
        && request.resource.data.severidad in ['critico', 'alto', 'medio', 'bajo']
        && request.resource.data.solucion is string
        && request.resource.data.solucion.size() <= 2000
        && request.resource.data.resumen is string
        && request.resource.data.resumen.size() <= 260
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdBy is string
        && request.resource.data.createdBy.size() <= 180;
    }

    function validBoletaExtranjera() {
      return hasOnly([
          'nBoleta', 'clienteDni', 'clienteNombre', 'totalPen', 'totalClp',
          'fechaHora', 'formato', 'origen', 'boletaData', 'createdAt'
        ])
        && request.resource.data.nBoleta is int
        && request.resource.data.nBoleta >= 1000
        && optionalString('clienteDni', 20)
        && optionalString('clienteNombre', 180)
        && request.resource.data.totalPen is number
        && request.resource.data.totalClp is number
        && optionalString('fechaHora', 40)
        && request.resource.data.formato in [1, 2, 3]
        && request.resource.data.origen in ['ventas', 'manual']
        && request.resource.data.boletaData is map
        && request.resource.data.createdAt is timestamp;
    }

    function validContadorBoletas() {
      return hasOnly(['last', 'updatedAt'])
        && request.resource.data.last is int
        && request.resource.data.last >= 999
        && request.resource.data.updatedAt is timestamp;
    }

    match /artifacts/{appId}/users/{scope}/clientes/{clienteId} {
      allow read: if canUseSharedData(appId, scope);
      allow create, update, delete: if false;
    }

    match /artifacts/{appId}/users/{scope}/equipos/{equipoId} {
      allow read: if canUseSharedData(appId, scope);
      allow create, update, delete: if false;
    }

    match /artifacts/{appId}/users/{scope}/registros/{registroId} {
      allow read: if canUseSharedData(appId, scope);
      allow create, update, delete: if false;
    }

    match /artifacts/{appId}/users/{scope}/ventas/{ventaId} {
      allow read: if canUseSharedData(appId, scope);
      allow create, update, delete: if false;
    }

    match /artifacts/{appId}/users/{scope}/configuracion/logoVentas {
      allow read: if canUseSharedData(appId, scope);
      allow create, update: if canUseSharedData(appId, scope) && validLogo();
      allow delete: if canUseSharedData(appId, scope);
    }

    match /artifacts/{appId}/users/{scope}/configuracion/contadorBoletas {
      allow read: if canUseSharedData(appId, scope);
      allow create, update: if canUseSharedData(appId, scope) && validContadorBoletas();
      allow delete: if false;
    }

    match /artifacts/{appId}/users/{scope}/configuracion/boletaExtranjeraEmisores {
      allow read: if canUseSharedData(appId, scope);
      allow create, update: if canUseSharedData(appId, scope) && validBoletaExtranjeraEmisores();
      allow delete: if false;
    }

    match /artifacts/{appId}/users/{scope}/problemasApp/{problemaId} {
      allow read: if canUseSharedData(appId, scope);
      allow create, update: if canUseSharedData(appId, scope) && validProblemaApp();
      allow delete: if false;
    }

    match /artifacts/{appId}/users/{scope}/changelogProblemas/{changelogId} {
      allow read: if canUseSharedData(appId, scope);
      allow create: if canUseSharedData(appId, scope) && validChangelogProblema();
      allow update, delete: if false;
    }

    match /artifacts/{appId}/users/{scope}/boletasExtranjeras/{boletaId} {
      allow read: if canUseSharedData(appId, scope);
      allow create: if canUseSharedData(appId, scope) && validBoletaExtranjera();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
